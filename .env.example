# Budget Bo - Environment Configuration
# Copy this file to .env and fill in your values

# Google OAuth Configuration (Required for Google login)
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Encryption Keys (Change these in production!)
SECRET_KEY=change_me_in_production_please_use_random_string
ENCRYPTION_KEY=generate_a_32_byte_key_for_fernet_

# Database (Defaults work with docker-compose)
POSTGRES_USER=budgetbo
POSTGRES_PASSWORD=budgetbo_secret
POSTGRES_DB=budgetbo

# Optional: Custom ports
# FRONTEND_URL=http://localhost:3000
