# Budget Bo - Environment Configuration
# Copy this file to .env and fill in your values

# Google OAuth Configuration (Required for Google login)
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Encryption Keys (Change these in production!)
SECRET_KEY=change_me_in_production_please_use_random_string
ENCRYPTION_KEY=generate_a_32_byte_key_for_fernet_

# Database (Defaults work with docker-compose)
POSTGRES_USER=budgetbo
POSTGRES_PASSWORD=budgetbo_secret
POSTGRES_DB=budgetbo

# Optional: Custom ports
# FRONTEND_URL=http://localhost:3000

# OAuth Configuration (Production only)
# OAUTH_BASE_URL=https://budget.victorsmits.com

# Gemini enrichment
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_BATCH_SIZE=50
GEMINI_DAILY_LIMIT=18
GEMINI_MIN_DELAY_SECONDS=12
# Enqueue strategy: split pending transactions into multiple jobs to reduce API spikes per worker
ENRICH_MAX_WORKERS=8
ENRICH_TARGET_API_CALLS_PER_JOB=2

# RQ worker implementation (SimpleWorker avoids fork/waitpid issues in constrained environments)
RQ_WORKER_CLASS=rq.SimpleWorker

# RQ worker implementation (SimpleWorker avoids fork/waitpid issues in constrained environments)
RQ_WORKER_CLASS=rq.SimpleWorker
